{
  "name": "@portfolio/db",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Drizzle schema + migrations (Postgres), shared types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
