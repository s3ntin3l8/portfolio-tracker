# Copy to .env and adjust. Safe defaults live in services/api/src/plugins/env.ts.

# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database (Postgres; Supabase Cloud or local docker-compose) ---
# Local compose default:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/portfolio
# For tests / driverless local runs, an embedded PGlite db is used automatically:
#   DATABASE_URL=pglite://./.pglite

# Optional. AES-256-GCM encryption-at-rest for flagged columns.
# base64url-encoded 32-byte key; empty disables it.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
DB_ENCRYPTION_KEY=

# --- Auth (Authentik OIDC) ---
# Point at your self-hosted Authentik instance. The API validates Bearer JWTs,
# checking issuer + audience. The signing keys (JWKS) are auto-discovered from the
# issuer via OIDC discovery, so AUTHENTIK_JWKS_URL is optional (set it only to
# override discovery). NOTE: Authentik puts the *client ID* in the token's `aud`,
# so AUTHENTIK_AUDIENCE must be the *client ID* (the long random string below), NOT
# the application slug. Leave it blank to skip the aud check entirely.
AUTHENTIK_ISSUER=https://auth.example.com/application/o/portfolio-tracker/
# AUTHENTIK_JWKS_URL=   # optional override; derived from the issuer when unset
# = AUTHENTIK_CLIENT_ID (Authentik puts the client ID in the token's `aud`).
AUTHENTIK_AUDIENCE=
# Members of this Authentik group may configure data providers from the admin UI.
# Empty ⇒ no admins. Authentik must emit the group in the token's `groups` claim
# (add a "groups" scope mapping to the application's OIDC provider).
AUTHENTIK_ADMIN_GROUP=
# Used by the web app's OIDC login flow (Auth.js v5 + Authentik provider).
# In Authentik, set the redirect URI to <web-origin>/api/auth/callback/authentik.
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
# Auth.js session/JWT encryption secret (web). Required once auth is enabled:
#   npx auth secret   # or: openssl rand -base64 32
AUTH_SECRET=
# Canonical web origin Auth.js uses to build the OIDC redirect_uri. REQUIRED for any
# non-localhost access (LAN IP, reverse-proxy domain): without it Auth.js guesses the
# origin from request headers and can emit a localhost/port-less redirect_uri that
# Authentik then rejects as a mismatch. Set it to the exact origin you browse to, and
# register <AUTH_URL>/api/auth/callback/authentik as the Authentik provider's redirect
# URI (Strict match — exact scheme, host, PORT, path, no trailing slash). The web app
# serves on :3005, so the callback path lives there, not on the API's :3000.
#   AUTH_URL=http://192.168.2.152:3005   →   .../api/auth/callback/authentik
AUTH_URL=http://localhost:3005
# Where the PWA reaches the Fastify API (browser-visible). Prod: same-origin behind
# the reverse proxy. Local dev: the web app runs on :3005 (see apps/web dev script)
# and the API on :3000 — different origins, so this points at the API and you must
# add the web origin to CORS_ORIGIN below. When browsing via a LAN IP / phone, use
# that same host here (e.g. http://192.168.2.152:3000), not localhost.
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Object storage (screenshots; Supabase Storage or local MinIO) ---
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=screenshots

# --- Screenshot parsing (ScreenshotParser) ---
# Pin a parser (claude | gemini | openrouter | ollama); leave blank to auto-select the
# first configured one in order: claude → gemini → openrouter.
SCREENSHOT_PARSER=claude
ANTHROPIC_API_KEY=
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
# Local vision fallback (Ollama or LM Studio); configurable host:port + model.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=qwen2.5vl:7b
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash

# --- Market data providers ---
# IDX: Twelve Data is the keyed primary; Yahoo Finance (.JK) is a keyless fallback,
# auto-registered with no env var (unofficial endpoint, fine for personal volume).
# iTick/Sectors free tiers are time-limited / lack API keys — left as future options.
ITICK_API_KEY=
SECTORS_API_KEY=
TWELVEDATA_API_KEY=
GOLDAPI_KEY=
# Gold buyback (Antam) for valuing gold *holdings* — a JSON endpoint returning a per-gram
# buyback price (field: buyback). Leave blank to use the built-in scraper: the scheduler
# scrapes the Antam LM buyback into the DB and this API serves it at
# /internal/gold/antam-buyback. Set only to point at an external endpoint instead.
ANTAM_BUYBACK_URL=
# Gold buyback (Galeri24) for valuing Galeri24 gold *holdings* — same JSON shape (field:
# buyback). Leave blank to use the built-in scraper: the scheduler scrapes the Galeri24
# buyback into the DB and this API serves it at /internal/gold/galeri24-buyback. Set only to
# point at an external endpoint instead.
GALERI24_BUYBACK_URL=
# Reksa-dana NAV source — a JSON endpoint resolved as <NAV_BASE_URL>/<fund-symbol>
# returning a per-unit NAV (field: nav). Leave blank to use the built-in Bibit scraper
# served at /internal/nav/<symbol>; store Bibit fund codes (e.g. RD4196) as the
# instrument symbol. Set only to point at an external endpoint instead.
NAV_BASE_URL=
# Base URL the Antam/NAV providers use to reach this API's own internal scraper routes
# (above). Defaults to http://127.0.0.1:$PORT; override if the API isn't reachable there.
MARKET_DATA_SELF_URL=
# OpenFIGI — resolves an ISIN to a ticker for instrument auto-discovery on manual
# transaction entry. Keyless works at a low rate limit; a free key raises it.
OPENFIGI_API_KEY=
# EODHD — keyed primary for EU/Xetra equities & ETFs (Trade Republic instruments),
# priced via the real-time endpoint and resolved by ISIN when needed. Leave blank to
# fall back to the keyless Yahoo (.DE) path, which also covers Xetra.
EODHD_API_KEY=
# CoinGecko — crypto pricing & history (keyless; Yahoo's BTC-USD path is the fallback).
# Always on. Optional free Demo key raises the rate limit and enables live quota reporting
# in the admin Data-providers view; leave blank to use keyless access.
COINGECKO_API_KEY=
# FX rates. Leave FX_BASE_URL blank to use the default keyless Frankfurter source
# (api.frankfurter.dev — ECB rates, current + historical daily series, covers IDR);
# this powers per-day historical net-worth conversion. Set FX_BASE_URL to override
# with a keyed exchangerate.host-style endpoint: GET <FX_BASE_URL>?base=<from>&symbols=<to>
# → { rates: { <to>: rate } } (current rates only, no historical backfill).
FX_BASE_URL=
# How long a cached last-price stays fresh before a live re-fetch (milliseconds).
# Portfolio valuation reads last_prices within this window instead of hitting
# providers on every request. Default 900000 (15 minutes).
MARKET_DATA_TTL_MS=900000

# --- HTTP ---
# Comma-separated CORS allowlist (needed once the web app is on a different origin,
# e.g. the local web app on :3005, or Vercel). Empty disables cross-origin requests.
# Must include every web origin you browse from — add the LAN IP origin too when
# testing from a phone, e.g. CORS_ORIGIN=http://192.168.2.152:3005,http://localhost:3005
CORS_ORIGIN=
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# --- Trade Republic (pytr) ---
# Python interpreter that runs the vendored pytr entrypoints (tr_login.py / tr_export.py).
# Must point at a Python that has `pytr` installed — otherwise the TR "Connect" flow
# fails with a 502. Run `make pytr-venv` to create .venv-pytr, then set this to its
# python using an ABSOLUTE path (the subprocess is spawned with cwd under services/api,
# so a relative path is ambiguous). Defaults to `python3`, which only works if the
# system python already has pytr. See docs/trade_republic.md.
#   PYTR_PYTHON_BIN=/abs/path/to/repo/.venv-pytr/bin/python
PYTR_PYTHON_BIN=
