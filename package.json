{
  "name": "portfolio-tracker",
  "version": "0.1.2",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Indonesian-first personal portfolio tracker (monorepo)",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=26"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:sharded": "vitest run --coverage --coverage.thresholds.lines=0 --coverage.thresholds.functions=0 --coverage.thresholds.branches=0 --coverage.thresholds.statements=0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "vite": "^8.0.0",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.10"
  }
}
