{
  "name": "portfolio-tracker",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Indonesian-first personal portfolio tracker (monorepo)",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=26"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.33.0"
  }
}
